  "private": true,
  "dependencies": {
    "react": "^16.9.0",
    "react-dom": "^16.9.0",
    "react-scripts": "3.1.2"
  },
  "//note": "NODE_OPTIONS=--openssl-legacy-provider is required because react-scripts 3.x uses an old webpack that relies on OpenSSL MD4, removed from Node 17+ default provider.",
